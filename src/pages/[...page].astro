---
import type { GetStaticPaths } from "astro";
import { Icon } from "astro-icon/components";
import Pagination from "../components/control/Pagination.astro";
import ImageWrapper from "../components/misc/ImageWrapper.astro";
import PostPage from "../components/PostPage.astro";
import { profileConfig } from "../config";
import { PAGE_SIZE } from "../constants/constants";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { getSortedPosts } from "../utils/content-utils";

export const getStaticPaths = (async ({ paginate }) => {
	const allBlogPosts = await getSortedPosts();
	return paginate(allBlogPosts, { pageSize: PAGE_SIZE });
}) satisfies GetStaticPaths;
// https://github.com/withastro/astro/issues/6507#issuecomment-1489916992

const { page } = Astro.props;

const len = page.data.length;
const isHome = page.currentPage === 1;
const skills = ["Android", "Kotlin", "Java"];
const timeline = [
	{
		year: "2016",
		title: "Androidエンジニアとしてキャリアを開始",
		description: "新卒入社からAndroidアプリ開発に携わり始めました。",
	},
	{
		year: "2020",
		title: "フリーランスとして活動",
		description: "Android開発を軸に、プロダクト開発の現場に関わりました。",
	},
	{
		year: "2021",
		title: "REALITY株式会社へ",
		description: "REALITYのAndroidアプリ開発に携わっています。",
	},
	{
		year: "Now",
		title: "Androidアプリ開発を中心に",
		description:
			"UI実装、Jetpack Compose、ビルド改善、起動時間改善などに関心があります。",
	},
];
---

{isHome ? (
    <MainGridLayout hideSidebar={true} hideSidebarWidgets={true}>
        <div class="space-y-4">
            <section class="card-base px-7 py-8 md:px-10 md:py-10 rounded-[var(--radius-large)]">
                <div class="flex flex-col md:flex-row md:items-center gap-7 md:gap-9">
                    <a href="/" aria-label="Go to Home Page" class="group relative block w-28 h-28 md:w-36 md:h-36 shrink-0 rounded-2xl overflow-hidden active:scale-95">
                        <div class="absolute transition pointer-events-none group-hover:bg-black/20 group-active:bg-black/40 w-full h-full z-10 flex items-center justify-center">
                            <Icon name="fa6-solid:house" class="transition opacity-0 scale-90 group-hover:scale-100 group-hover:opacity-100 text-white text-4xl"></Icon>
                        </div>
                        <ImageWrapper src={profileConfig.avatar || ""} alt="Profile Image of tk-zzz" class="w-full h-full"></ImageWrapper>
                    </a>
                    <div class="min-w-0">
                        <p class="transition text-sm font-bold text-[var(--primary)] mb-3 m-0">Android Engineer</p>
                        <h1 class="transition text-90 text-4xl md:text-5xl font-bold leading-tight mb-4">
                            {profileConfig.name}
                        </h1>
                        <p class="transition text-75 text-lg leading-8 max-w-2xl m-0">
                            2016年からAndroidエンジニアをやっています。現在はREALITY株式会社でAndroidアプリ開発に携わっています。
                        </p>
                        <div class="flex flex-wrap gap-2 mt-6">
                            {profileConfig.links.map((item) => (
                                <a rel="me" aria-label={item.name} href={item.url} target="_blank" class="btn-regular rounded-lg h-10 gap-2 px-3 font-bold active:scale-95">
                                    <Icon name={item.icon} class="text-[1.25rem]"></Icon>
                                    <span class="text-sm">{item.name}</span>
                                </a>
                            ))}
                        </div>
                    </div>
                </div>
            </section>

            <section class="card-base px-7 py-8 md:px-10 md:py-10 rounded-[var(--radius-large)]">
                <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_18rem]">
					<div>
						<p class="transition text-sm font-bold text-[var(--primary)] mb-3 m-0">About</p>
						<p class="transition text-75 leading-8 m-0">
							AndroidアプリのUI実装、Jetpack Compose、ビルド改善、アプリ起動時間の高速化などに関心があります。開発合宿の運営や、REALITY Tech Blog・Zennでの技術記事執筆もしています。
						</p>
                    </div>
                    <div>
                        <p class="transition text-sm font-bold text-50 mb-3 m-0">Skill</p>
                        <div class="flex flex-wrap gap-2">
                            {skills.map((skill) => (
                                <span class="transition rounded-lg bg-black/[0.04] dark:bg-white/[0.08] text-75 px-3 py-2 text-sm font-bold">
                                    {skill}
                                </span>
                            ))}
                        </div>
                    </div>
                </div>
            </section>

			<section class="card-base px-7 py-8 md:px-10 md:py-10 rounded-[var(--radius-large)]">
				<p class="transition text-sm font-bold text-[var(--primary)] mb-3 m-0">Timeline</p>
				<div class="relative">
                    <div class="absolute left-[4.25rem] md:left-[5.25rem] top-2 bottom-2 w-px bg-black/10 dark:bg-white/15"></div>
                    <div class="space-y-7">
                        {timeline.map((item) => (
                            <div class="relative grid grid-cols-[4.25rem_minmax(0,1fr)] md:grid-cols-[5.25rem_minmax(0,1fr)] gap-5">
                                <div class="transition text-75 font-bold leading-7">{item.year}</div>
                                <div class="relative pl-7">
                                    <div class="absolute -left-[0.3rem] top-2 h-3 w-3 rounded-full bg-[var(--primary)] ring-4 ring-[var(--card-bg)]"></div>
                                    <h3 class="transition text-90 font-bold text-lg mb-2">{item.title}</h3>
                                    <p class="transition text-50 leading-7 m-0">{item.description}</p>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
            </section>
        </div>
    </MainGridLayout>
) : (
    <MainGridLayout>
        <PostPage page={page}></PostPage>
        <Pagination class="mx-auto onload-animation" page={page} style={`animation-delay: calc(var(--content-delay) + ${(len)*50}ms)`}></Pagination>
    </MainGridLayout>
)}
